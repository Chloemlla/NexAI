<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NexAI.WinUI3.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:chat="using:NexAI.Core.Chat"
    xmlns:controls="using:NexAI.WinUI3.Controls"
    Background="Transparent"
    mc:Ignorable="d">
    <Grid Padding="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="ConversationsTitleText" Style="{StaticResource SubtitleTextBlockStyle}" Text="Conversations" />
                        <TextBlock
                            x:Name="ConversationCountText"
                            Opacity="0.72"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="0 chats" />
                    </StackPanel>
                    <Button
                        x:Name="NewChatButton"
                        Grid.Column="1"
                        Content="New"
                        MinWidth="72"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="NewChatButton_Click" />
                </Grid>

                <TextBox
                    x:Name="SearchBox"
                    Grid.Row="1"
                    Margin="0,12,0,12"
                    PlaceholderText="Search conversations"
                    TextChanged="SearchBox_TextChanged" />

                <Grid Grid.Row="2">
                    <ListView
                        x:Name="ConversationList"
                        SelectionMode="Single"
                        IsItemClickEnabled="True"
                        ItemClick="ConversationList_ItemClick">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="4,2" />
                                <Setter Property="MinHeight" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="chat:Conversation">
                                <Grid Padding="8,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock
                                            Text="{x:Bind Title}"
                                            TextWrapping="NoWrap"
                                            TextTrimming="CharacterEllipsis"
                                            Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock
                                            Text="{x:Bind Preview}"
                                            Opacity="0.72"
                                            TextWrapping="NoWrap"
                                            TextTrimming="CharacterEllipsis"
                                            Style="{StaticResource CaptionTextBlockStyle}" />
                                    </StackPanel>
                                    <Button
                                        Grid.Column="1"
                                        Width="32"
                                        Height="32"
                                        Padding="0"
                                        VerticalAlignment="Top"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Tag="{x:Bind Id}"
                                        Click="DeleteConversationButton_Click"
                                        x:Name="DeleteConversationTooltipHost" ToolTipService.ToolTip="Delete conversation">
                                        <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel
                        x:Name="ConversationEmptyState"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        Visibility="Collapsed">
                        <FontIcon Glyph="&#xE8BD;" FontSize="24" />
                        <TextBlock x:Name="ConversationEmptyTitleText" Text="No conversations" HorizontalAlignment="Center" />
                        <TextBlock
                            Opacity="0.72"
                            HorizontalAlignment="Center"
                            x:Name="ConversationEmptySubtitleText" Text="Create a chat to get started." />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2">
                    <TextBlock
                        x:Name="CurrentTitleText"
                        Style="{StaticResource TitleLargeTextBlockStyle}"
                        Text="Chat" />
                    <TextBlock
                        x:Name="CurrentMetaText"
                        Opacity="0.72"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="Select or create a conversation." />
                </StackPanel>
                <Button
                    x:Name="DeleteCurrentButton"
                    Grid.Column="1"
                    Content="Delete"
                    IsEnabled="False"
                    Click="DeleteCurrentButton_Click" />
            </Grid>

            <Border
                Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8">
                <Grid>
                    <ListView
                        x:Name="MessageList"
                        SelectionMode="None"
                        IsItemClickEnabled="False"
                        ContainerContentChanging="MessageList_ContainerContentChanging">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="4,4" />
                                <Setter Property="MinHeight" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="chat:ChatMessage">
                                <Border
                                    Margin="4,4"
                                    Padding="14,12"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <controls:MarkdownMessagePresenter Message="{x:Bind}" />
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel
                        x:Name="MessageEmptyState"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Visibility="Collapsed">
                        <FontIcon Glyph="&#xE8F2;" FontSize="28" />
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            HorizontalAlignment="Center"
                            x:Name="MessageEmptyTitleText" Text="No messages yet" />
                        <TextBlock
                            Opacity="0.72"
                            HorizontalAlignment="Center"
                            x:Name="MessageEmptySubtitleText" Text="Send a message to start streaming from your configured API." />
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                Grid.Row="2"
                Margin="0,12,0,0"
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="ComposerBox"
                        PlaceholderText="Message NexAI..."
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        MinHeight="72"
                        MaxHeight="160"
                        TextChanged="ComposerBox_TextChanged"
                        PreviewKeyDown="ComposerBox_PreviewKeyDown" />
                    <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Bottom">
                        <Button
                            x:Name="SendButton"
                            Content="Send"
                            MinWidth="108"
                            MinHeight="36"
                            Style="{StaticResource AccentButtonStyle}"
                            IsEnabled="False"
                            Click="SendButton_Click" />
                        <Button
                            x:Name="StopButton"
                            Content="Stop"
                            MinWidth="108"
                            MinHeight="36"
                            Visibility="Collapsed"
                            Click="StopButton_Click" />
                        <TextBlock
                            x:Name="ComposerHintText"
                            Width="108"
                            Opacity="0.72"
                            TextWrapping="Wrap"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="Ready" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
