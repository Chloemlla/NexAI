<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NexAI.WinUI3.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="NexAI">
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Padding="16,0,16,0" Background="Transparent" Canvas.ZIndex="1">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Image Width="18" Height="18" Source="ms-appx:///Assets/icon.png" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" Text="NexAI" />
            </StackPanel>
        </Grid>

        <NavigationView
            x:Name="RootNavigation"
            Grid.Row="0"
            Grid.RowSpan="2"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneOpen="True"
            OpenPaneLength="260"
            CompactPaneLength="48"
            PaneDisplayMode="Left"
            SelectionChanged="RootNavigation_SelectionChanged"
            Loaded="RootNavigation_Loaded">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Chat" Tag="chat">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8BD;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Notes" Tag="notes">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE70B;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Tools" Tag="tools">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xEC7A;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Settings" Tag="settings">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE713;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Frame x:Name="ContentFrame" Grid.Row="1" />
                <InfoBar
                    x:Name="SoftSigInfoBar"
                    Grid.Row="1"
                    VerticalAlignment="Top"
                    Margin="16,8,16,0"
                    IsOpen="False"
                    IsClosable="True"
                    Severity="Warning"
                    Title="Signature notice" />
            </Grid>
        </NavigationView>
    </Grid>
</Window>
