<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NexAI.WinUI3.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="NexAI">
    <!-- Keep first paint minimal: no ms-appx images, no system backdrop, no custom chrome. -->
    <Grid x:Name="RootGrid">
        <NavigationView
            x:Name="RootNavigation"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneOpen="True"
            OpenPaneLength="240"
            CompactPaneLength="48"
            PaneDisplayMode="Left"
            SelectionChanged="RootNavigation_SelectionChanged"
            Loaded="RootNavigation_Loaded">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Chat" Tag="chat" />
                <NavigationViewItem Content="Notes" Tag="notes" />
                <NavigationViewItem Content="Tools" Tag="tools" />
                <NavigationViewItem Content="Settings" Tag="settings" />
            </NavigationView.MenuItems>
            <Grid>
                <Frame x:Name="ContentFrame" />
                <InfoBar
                    x:Name="SoftSigInfoBar"
                    VerticalAlignment="Top"
                    Margin="16,8,16,0"
                    IsOpen="False"
                    IsClosable="True"
                    Severity="Warning"
                    Title="Signature notice" />
            </Grid>
        </NavigationView>
    </Grid>
</Window>
