<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NexAI.WinUI3.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">
    <ScrollViewer Padding="24">
        <StackPanel MaxWidth="720" Spacing="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource TitleLargeTextBlockStyle}" Text="Settings" />
                    <TextBlock
                        Opacity="0.72"
                        Text="Configure the OpenAI-compatible endpoint used by the native Windows client." />
                </StackPanel>
                <Button
                    x:Name="SaveButton"
                    Grid.Column="1"
                    Content="Save"
                    MinWidth="96"
                    MinHeight="36"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="SaveButton_Click" />
            </Grid>

            <Border
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="API" />
                    <TextBox
                        x:Name="BaseUrlBox"
                        Header="Base URL"
                        PlaceholderText="https://api.openai.com/v1" />
                    <PasswordBox
                        x:Name="ApiKeyBox"
                        Header="API Key"
                        PlaceholderText="sk-..." />
                    <TextBox
                        x:Name="ModelBox"
                        Header="Model"
                        PlaceholderText="gpt-4o-mini" />
                    <NumberBox
                        x:Name="TemperatureBox"
                        Header="Temperature"
                        Minimum="0"
                        Maximum="2"
                        SmallChange="0.1"
                        LargeChange="0.5"
                        SpinButtonPlacementMode="Inline"
                        ValidationMode="InvalidInputOverwritten" />
                    <NumberBox
                        x:Name="MaxTokensBox"
                        Header="Max tokens"
                        Minimum="1"
                        Maximum="128000"
                        SmallChange="64"
                        LargeChange="256"
                        SpinButtonPlacementMode="Inline"
                        ValidationMode="InvalidInputOverwritten" />
                </StackPanel>
            </Border>

            <Border
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Appearance" />
                    <ComboBox
                        x:Name="ThemeBox"
                        Header="Theme"
                        MinWidth="220"
                        SelectionChanged="ThemeBox_SelectionChanged">
                        <ComboBoxItem Content="System" Tag="System" />
                        <ComboBoxItem Content="Light" Tag="Light" />
                        <ComboBoxItem Content="Dark" Tag="Dark" />
                    </ComboBox>
                    <TextBlock
                        Opacity="0.72"
                        Text="Theme applies immediately and is persisted when you save." />
                </StackPanel>
            </Border>

            <TextBlock
                x:Name="StatusText"
                Opacity="0.8"
                TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
