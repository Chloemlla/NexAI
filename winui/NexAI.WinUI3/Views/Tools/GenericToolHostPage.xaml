<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NexAI.WinUI3.Views.Tools.GenericToolHostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="BackButton" Content="Back" Click="BackButton_Click" />
            <StackPanel Spacing="2">
                <TextBlock x:Name="ToolTitle" Style="{StaticResource TitleLargeTextBlockStyle}" Text="Tool" />
                <TextBlock x:Name="ToolDescription" Opacity="0.72" TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>

        <Border
            Grid.Row="1"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16">
            <ScrollViewer>
                <StackPanel Spacing="12">
                    <TextBox x:Name="InputBox" Header="Input" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="RunButton" Content="Run" Style="{StaticResource AccentButtonStyle}" Click="RunButton_Click" />
                        <Button Content="Copy output" Click="CopyButton_Click" />
                    </StackPanel>
                    <TextBox x:Name="OutputBox" Header="Output" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="160" IsReadOnly="True" />
                    <TextBlock x:Name="ToolStatus" Opacity="0.72" TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
