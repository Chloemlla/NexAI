<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NexAI.WinUI3.Views.Tools.PasswordToolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Back" Click="BackButton_Click" />
            <StackPanel Spacing="2">
                <TextBlock Style="{StaticResource TitleLargeTextBlockStyle}" Text="Password Generator" />
                <TextBlock x:Name="SubtitleText" Opacity="0.72" Text="Generate random / memorable / PIN passwords with vault and encrypted backup." TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>

        <CommandBar Grid.Row="1" DefaultLabelPosition="Right" Background="Transparent">
            <AppBarButton Icon="Copy" Label="Copy" Click="CopyCurrent_Click" />
            <AppBarButton Icon="Refresh" Label="Regenerate" Click="Regenerate_Click" />
            <AppBarButton Icon="Save" Label="Save" Click="SaveCurrent_Click" />
            <AppBarButton Icon="Download" Label="Export CSV" Click="ExportSaved_Click" />
            <AppBarButton Icon="Upload" Label="Backup" Click="Backup_Click" />
            <AppBarButton Icon="OpenLocal" Label="Restore" Click="Restore_Click" />
            <AppBarButton Icon="Delete" Label="Clear vault" Click="ClearVault_Click" />
        </CommandBar>

        <Pivot Grid.Row="2">
            <PivotItem Header="Generate">
                <ScrollViewer>
                    <StackPanel Spacing="16" Padding="0,12,0,12">
                        <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel Spacing="12">
                                <TextBox x:Name="GeneratedBox" Header="Generated password" IsReadOnly="True" FontFamily="Consolas" FontSize="20" TextWrapping="Wrap" />
                                <ProgressBar x:Name="StrengthBar" Minimum="0" Maximum="100" Height="8" />
                                <TextBlock x:Name="StrengthText" Opacity="0.8" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Copy" Click="CopyCurrent_Click" />
                                    <Button Content="Regenerate" Click="Regenerate_Click" />
                                    <Button Content="Save" Style="{StaticResource AccentButtonStyle}" Click="SaveCurrent_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel Spacing="12">
                                <ComboBox x:Name="TypeBox" Header="Password type" MinWidth="220" SelectionChanged="TypeBox_SelectionChanged">
                                    <ComboBoxItem Content="Random" Tag="Random" IsSelected="True" />
                                    <ComboBoxItem Content="Memorable" Tag="Memorable" />
                                    <ComboBoxItem Content="PIN" Tag="Pin" />
                                </ComboBox>

                                <StackPanel x:Name="RandomPanel" Spacing="8">
                                    <Slider x:Name="LengthSlider" Header="Length" Minimum="4" Maximum="32" Value="16" StepFrequency="1" ValueChanged="Options_Changed" />
                                    <ToggleSwitch x:Name="UpperToggle" Header="Uppercase (A-Z)" IsOn="True" Toggled="Options_Changed" />
                                    <ToggleSwitch x:Name="LowerToggle" Header="Lowercase (a-z)" IsOn="True" Toggled="Options_Changed" />
                                    <ToggleSwitch x:Name="NumberToggle" Header="Numbers (0-9)" IsOn="True" Toggled="Options_Changed" />
                                    <ToggleSwitch x:Name="SymbolToggle" Header="Symbols (!@#$)" IsOn="True" Toggled="Options_Changed" />
                                </StackPanel>

                                <StackPanel x:Name="MemorablePanel" Spacing="8" Visibility="Collapsed">
                                    <Slider x:Name="WordCountSlider" Header="Word count" Minimum="2" Maximum="6" Value="4" StepFrequency="1" ValueChanged="Options_Changed" />
                                    <ToggleSwitch x:Name="CapitalizeToggle" Header="Capitalize words" IsOn="True" Toggled="Options_Changed" />
                                    <ToggleSwitch x:Name="AddNumbersToggle" Header="Append numbers" IsOn="True" Toggled="Options_Changed" />
                                </StackPanel>

                                <StackPanel x:Name="PinPanel" Spacing="8" Visibility="Collapsed">
                                    <Slider x:Name="PinLengthSlider" Header="PIN length" Minimum="4" Maximum="12" Value="6" StepFrequency="1" ValueChanged="Options_Changed" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <PivotItem Header="Batch">
                <ScrollViewer>
                    <StackPanel Spacing="12" Padding="0,12,0,12">
                        <Slider x:Name="BatchCountSlider" Header="Batch count" Minimum="1" Maximum="50" Value="10" StepFrequency="1" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Generate batch" Style="{StaticResource AccentButtonStyle}" Click="GenerateBatch_Click" />
                            <Button Content="Export batch CSV" Click="ExportBatch_Click" />
                        </StackPanel>
                        <ListView x:Name="BatchList" MaxHeight="420" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4,8" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" IsTextSelectionEnabled="True" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="Copy" Tag="{Binding}" Click="CopyBatchItem_Click" />
                                        <Button Grid.Column="2" Content="Save" Tag="{Binding}" Click="SaveBatchItem_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <PivotItem Header="Saved">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="SavedCountText" Opacity="0.75" />
                    <ListView x:Name="SavedList" Grid.Row="1" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="0,4" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Category}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{Binding Password}" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                                            <TextBlock Text="{Binding Note}" Opacity="0.7" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Copy" Tag="{Binding}" Click="CopySaved_Click" />
                                        <Button Grid.Column="2" Content="Delete" Tag="{Binding}" Click="DeleteSaved_Click" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
