<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NexAI.WinUI3.Views.Tools.ShortUrlToolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <ScrollViewer Padding="16">
        <StackPanel MaxWidth="820" Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Back" Click="BackButton_Click" />
                <StackPanel Spacing="2">
                    <TextBlock Style="{StaticResource TitleLargeTextBlockStyle}" Text="Short URL" />
                    <TextBlock Opacity="0.72" Text="Create short links via api.mmp.cc and keep a local history." TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Paste URL" Click="PasteButton_Click" />
                <Button Content="Clear" Click="ClearButton_Click" />
                <Button x:Name="OpenButton" Content="Open result" Click="OpenButton_Click" IsEnabled="False" />
            </StackPanel>

            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBox x:Name="UrlBox" Header="Long URL" PlaceholderText="https://example.com/very/long/path" TextWrapping="Wrap" />
                    <Button x:Name="CreateButton" Content="Create short link" Style="{StaticResource AccentButtonStyle}" Click="CreateButton_Click" />
                    <TextBlock x:Name="StatusText" Opacity="0.8" TextWrapping="Wrap" />
                    <TextBox x:Name="ResultBox" Header="Short URL" IsReadOnly="True" />
                    <Button Content="Copy short URL" Click="CopyButton_Click" />
                </StackPanel>
            </Border>

            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="History" />
                    <ListView x:Name="HistoryList" MaxHeight="280" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="4,8" Spacing="2">
                                    <TextBlock Text="{Binding ShortUrl}" Style="{StaticResource BodyStrongTextBlockStyle}" IsTextSelectionEnabled="True" />
                                    <TextBlock Text="{Binding OriginalUrl}" Opacity="0.7" TextWrapping="WrapWholeWords" IsTextSelectionEnabled="True" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Button Content="Clear history" Click="ClearHistory_Click" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
